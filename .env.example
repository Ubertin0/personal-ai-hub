# ==========================================
# Secure Corporate AI Gateway - Config
# ==========================================

# OpenRouter API Configuration
OPENAI_API_KEY=your_openrouter_api_key_here
BASE_URL=https://openrouter.ai/api

# Allowed Models (Free/Paid selection)
CUSTOM_MODELS=+arcee-ai/trinity-large-preview:free,+z-ai/glm-4.5-air:free,+stepfun/step-3.5-flash:free,+meta-llama/llama-3.3-70b-instruct:free,+openrouter/free

# Xray Core Proxy Target (Internal Docker Network)
PROXY_URL=socks5://xray-router:40000

# UI Security
HIDE_USER_API_KEY=1
CODE=strong_password_1,strong_password_2
